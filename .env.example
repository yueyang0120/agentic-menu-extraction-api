OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Optional legacy static token support. Leave unset to disable legacy auth.
BACKEND_API_SECRET=

# Optional registration guard. When set, /auth/register requires X-Registration-Secret.
MASTER_SECRET=replace_with_a_private_registration_secret

AUTH_WINDOW_SECONDS=300
MAX_OUTPUT_TOKENS=16000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional. Without DATABASE_URL the service uses local SQLite devices.db.
DATABASE_URL=
